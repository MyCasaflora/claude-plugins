#!/usr/bin/env python3
"""
EUR-Lex SPARQL Client
Abfrage des EU Publications Office SPARQL Endpoints.
Endpoint: https://publications.europa.eu/webapi/rdf/sparql

Usage:
  python3 eurlex-sparql-query.py --query "GDPR"
  python3 eurlex-sparql-query.py --celex "32016R0679"
  python3 eurlex-sparql-query.py --topic "artificial intelligence"
"""

import argparse
import json
import ssl
import sys
import urllib.request
import urllib.parse

SSL_CTX = ssl.create_default_context()
SSL_CTX.check_hostname = False
SSL_CTX.verify_mode = ssl.CERT_NONE


ENDPOINT = "https://publications.europa.eu/webapi/rdf/sparql"


def execute_sparql(query: str) -> dict:
    """Führt eine SPARQL-Abfrage aus."""
    data = urllib.parse.urlencode({
        "query": query,
    }).encode("utf-8")

    req = urllib.request.Request(ENDPOINT, data=data, headers={
        "Accept": "application/sparql-results+json",
        "Content-Type": "application/x-www-form-urlencoded",
        "User-Agent": "beratungs-suite/1.0"
    })
    with urllib.request.urlopen(req, timeout=30, context=SSL_CTX) as resp:
        return json.loads(resp.read().decode("utf-8"))


def search_by_keyword(keyword: str, limit: int = 10) -> dict:
    """Suche nach EU-Rechtsakten per Stichwort."""
    query = f"""
    PREFIX cdm: <http://publications.europa.eu/ontology/cdm#>
    PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

    SELECT DISTINCT ?work ?title ?celex ?date
    WHERE {{
      ?work cdm:work_has_resource-type <http://publications.europa.eu/resource/authority/resource-type/REG> .
      ?work cdm:resource_legal_title ?title .
      ?work cdm:resource_legal_id_celex ?celex .
      OPTIONAL {{ ?work cdm:work_date_document ?date . }}
      FILTER(CONTAINS(LCASE(?title), LCASE("{keyword}")))
    }}
    ORDER BY DESC(?date)
    LIMIT {limit}
    """
    return execute_sparql(query)


def get_by_celex(celex: str) -> dict:
    """Hole einen EU-Rechtsakt per CELEX-Nummer."""
    query = f"""
    PREFIX cdm: <http://publications.europa.eu/ontology/cdm#>

    SELECT ?work ?title ?date ?type
    WHERE {{
      ?work cdm:resource_legal_id_celex "{celex}" .
      ?work cdm:resource_legal_title ?title .
      OPTIONAL {{ ?work cdm:work_date_document ?date . }}
      OPTIONAL {{ ?work cdm:work_has_resource-type ?type . }}
      FILTER(LANG(?title) = "de" || LANG(?title) = "en")
    }}
    LIMIT 5
    """
    return execute_sparql(query)


def format_results(data: dict) -> str:
    """Formatiert SPARQL-Ergebnisse als lesbaren Text."""
    output = []
    bindings = data.get("results", {}).get("bindings", [])

    output.append(f"Treffer: {len(bindings)}\n")

    for i, b in enumerate(bindings, 1):
        title = b.get("title", {}).get("value", "N/A")
        celex = b.get("celex", {}).get("value", "N/A")
        date = b.get("date", {}).get("value", "N/A")
        work = b.get("work", {}).get("value", "N/A")

        output.append(f"{i}. {title}")
        output.append(f"   CELEX: {celex}")
        output.append(f"   Datum: {date}")
        output.append(f"   URI: {work}")
        output.append("")

    return "\n".join(output)


def main():
    parser = argparse.ArgumentParser(description="EUR-Lex SPARQL Client")
    parser.add_argument("--query", "-q", help="Stichwortsuche")
    parser.add_argument("--celex", "-c", help="CELEX-Nummer (z.B. 32016R0679 für DSGVO)")
    parser.add_argument("--limit", "-l", type=int, default=10, help="Max. Ergebnisse")
    parser.add_argument("--json", action="store_true", help="Rohe JSON-Ausgabe")

    args = parser.parse_args()

    if not args.query and not args.celex:
        parser.error("Entweder --query oder --celex angeben")

    try:
        if args.celex:
            result = get_by_celex(args.celex)
        else:
            result = search_by_keyword(args.query, args.limit)

        if args.json:
            print(json.dumps(result, indent=2, ensure_ascii=False))
        else:
            print(format_results(result))

    except urllib.error.HTTPError as e:
        print(f"HTTP-Fehler: {e.code} {e.reason}", file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"Verbindungsfehler: {e.reason}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
